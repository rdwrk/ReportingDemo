<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] — Reporting Demo</title>
    <style>
        body { font-family: Calibri, sans-serif; margin: 0; background: #f0f2f5; }
        nav { background: #1F3864; padding: 12px 24px; color: white; display: flex; gap: 24px; align-items: center; }
        nav a { color: #AEC6E8; text-decoration: none; font-size: 14px; }
        nav a:hover { color: white; }
        nav .brand { color: white; font-size: 16px; font-weight: bold; margin-right: 16px; }
        .container { max-width: 700px; margin: 32px auto; }
        .card { background: white; padding: 28px; border-radius: 8px; box-shadow: 0 1px 6px rgba(0,0,0,.12); }
        h2 { color: #1F3864; margin-top: 0; }
        label { display: block; font-weight: 600; margin: 12px 0 4px; color: #333; font-size: 14px; }
        input, select { width: 100%; padding: 7px 10px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box; font-size: 14px; }
        .buttons { margin-top: 20px; display: flex; gap: 10px; }
        .btn { padding: 9px 22px; border: none; border-radius: 4px; cursor: pointer; font-size: 14px; font-weight: 600; }
        .btn-primary { background: #2E75B6; color: white; }
        .btn-secondary { background: #555; color: white; }
        .btn:hover { opacity: .88; }
        iframe.pdf-viewer { width: 100%; height: 72vh; border: none; margin-top: 20px; border-radius: 6px; box-shadow: 0 1px 6px rgba(0,0,0,.15); }
    </style>
</head>
<body>
    <nav>
        <span class="brand">📊 Reporting Demo</span>
        <a href="/SalesReport">Sales Report</a>
        <a href="/InvoiceReport">Invoice Report</a>
        <a href="/RegionSummary">Region Summary</a>
    </nav>
    <div class="container">
        @RenderBody()
    </div>
</body>
</html>
